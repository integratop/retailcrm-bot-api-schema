{
  "name": "@integratop/retailcrm-bot-api-schema",
  "version": "1.0.0",
  "description": "RetailCRM Bot API OpenApi Specification",
  "private": true,
  "author": {
    "name": "Dmitriy Chudnyi",
    "url": "https://www.chudnyi.com",
    "email": "dmitriy@chudnyi.com"
  },
  "license": "MIT",
  "keywords": [
    "retailcrm",
    "api",
    "schema",
    "rest",
    "json",
    "specification",
    "bot",
    "openapi",
    "open-api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/integratop/retailcrm-bot-api-schema.git"
  },
  "scripts": {
    "clean": "rm -fr dist",
    "download-schema": "curl -fsSL ${RETAIL_CRM_BOT_API_SCHEMA_URL?'Required'} -o src/schemas/schema.json",
    "gen-schema-ts": "scripts/gen-schema-ts.ts < src/schemas/schema.json > src/schema.ts",
    "pretty-schema-ts": "pnpm prettier --write src/schema.ts",
    "compile": "tsdown",
    "strip-comments": "scripts/strip-comments.ts ./dist/*.{js,d.ts}",
    "pretty-dist": "pnpm prettier --write ./dist/*.{js,d.ts}",
    "copy-dist-files": "cp -r README.md src/schemas ./dist",
    "gen-package-json": "scripts/gen-package-json.ts < package.json > dist/package.json",
    "build": "pnpm gen-schema-ts && pnpm pretty-schema-ts && pnpm compile && pnpm strip-comments && pnpm pretty-dist && pnpm copy-dist-files && pnpm gen-package-json",
    "lint": "tsc",
    "test": "vitest --run",
    "test:node": "pkgx +nodejs.org@14.21.3 /usr/bin/env -S sh -c 'dist/cli.js --json > /dev/null && dist/cli.js --yaml > /dev/null'",
    "release-commitlint": "pnpm commitlint --from main",
    "release": "pnpm release-please"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "openapi-types": "^12.1.3",
    "yaml": "^2.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.6",
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "11.0.5",
    "@semantic-release/npm": "12.0.2",
    "@semantic-release/release-notes-generator": "14.0.3",
    "@types/node": "^24.3.1",
    "@types/strip-comments": "^2.0.4",
    "desm": "^1.3.1",
    "prettier": "^3.6.2",
    "release-please": "17.1.2",
    "semantic-release": "24.2.7",
    "strip-comments": "^2.0.1",
    "tsdown": "^0.14.2",
    "tsx": "4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">= 24.0.0"
  },
  "type": "module",
  "bin": "./dist/cli.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./schemas/schema.json": "./src/schemas/schema.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json",
      "./schemas/schema.json": "./src/schemas/schema.json"
    },
    "engines": {
      "node": ">= 14.21.3"
    }
  },
  "packageManager": "pnpm@10.15.1"
}
